# 운영용 docker-compose 예시.
# 파일 복사 후 <...> 자리에 실제 값을 채워서 사용한다.
# 환경변수 설명은 각 앱의 README를 참조한다.

services:
  scheduler:
    image: ghcr.io/dove-kim/dove-lab/scheduler:latest
    container_name: scheduler
    restart: unless-stopped
    environment:
      DB_HOST: <DB 호스트>
      DB_PORT: <DB 포트>
      DB_USERNAME: <DB 사용자명>
      DB_PASSWORD: <DB 비밀번호>
      KRX_API_AUTH_KEY: <한국거래소 API 인증키>
      KRX_TARGET_MARKETS: "KOSPI,KOSDAQ"
      MARKET_INITIAL_DATE: "2010-01-01"
    volumes:
      - ./logs/scheduler:/logs
    network_mode: "host"

  api:
    image: ghcr.io/dove-kim/dove-lab/api:latest
    container_name: api
    restart: unless-stopped
    environment:
      SERVER_PORT: ${API_PORT:-8081}
      DB_HOST: <DB 호스트>
      DB_PORT: <DB 포트>
      DB_USERNAME: <DB 사용자명>
      DB_PASSWORD: <DB 비밀번호>
      JWT_SECRET: <JWT 서명 키 (32자 이상, 반드시 변경)>
      JWT_EXPIRATION_MS: 3600000
      JWT_REMEMBER_ME_EXPIRATION_MS: 2592000000
      INIT_ADMIN_USERNAME: <최초 ROOT 계정 아이디 (최초 1회)>
      INIT_ADMIN_PASSWORD: <최초 ROOT 계정 비밀번호 (최초 1회)>
    volumes:
      - ./logs/api:/logs
    network_mode: "host"

  web:
    image: ghcr.io/dove-kim/dove-lab/web:latest
    container_name: web
    restart: unless-stopped
    environment:
      PORT: ${WEB_PORT:-3000}
      INTERNAL_API_URL: http://localhost:${API_PORT:-8081}
    network_mode: "host"
